---
const domains = [
['govern','Govern','Gobierno y dirección',['Estrategia formal aprobada por Dirección','Riesgos revisados por Alta Dirección','Presupuesto específico de ciberseguridad','Política corporativa documentada','Responsable definido','Evaluación de proveedores críticos','Indicadores revisados con negocio','Mejora continua de riesgos']],
['identify','Identify','Activos y riesgos',['Inventario de activos críticos','Inventario de software','Clasificación de información','Mapa de red actualizado','Inventario de proveedores','Inventario OT cuando aplica','Evaluaciones periódicas de riesgo','Servicios cloud identificados']],
['protect','Protect','Controles preventivos',['MFA en accesos críticos','Respaldos protegidos y monitoreados','EDR/antimalware administrado','Firewalls administrados','Segmentación de red','Hardening y actualización','Awareness de seguridad','Privilegios mínimos']],
['detect','Detect','Monitoreo y visibilidad',['Recolección de logs críticos','SIEM/XDR/correlación','SOC o monitoreo formal','Alertas críticas priorizadas','Monitoreo de disponibilidad','Escaneo de vulnerabilidades','Monitoreo OT cuando aplica','Threat Intelligence']],
['respond','Respond','Respuesta a incidentes',['Plan formal de respuesta','Roles definidos','Simulacros o ejercicios','Matriz de comunicación','Capacidad forense o apoyo externo','Procedimientos de contención','Lecciones aprendidas','Relación legal/autoridades/aseguradora']],
['recover','Recover','Continuidad y recuperación',['DRP tecnológico','BCP para procesos críticos','Pruebas de recuperación','RTO definidos','RPO definidos','Backups offline/inmutables','Estrategias alternas de continuidad','Recuperación OT cuando aplica']]
];
const scale=['0 - No existe','1 - Inicial','2 - Parcial','3 - Implementado','4 - Gestionado','5 - Optimizado'];
---
<html lang="es"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Cyber Maturity Assessment | ALLUNIFIED</title><style>
:root{--bg:#020817;--cyan:#22d3ee;--ink:#0f172a;--muted:#64748b;--soft:#f4f7fb;--line:#e2e8f0}*{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,sans-serif;background:var(--bg);color:white}a{text-decoration:none;color:inherit}.container{width:min(1180px,calc(100% - 40px));margin:auto}.header{position:sticky;top:0;z-index:30;background:rgba(2,8,23,.86);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,.1)}.nav{height:82px;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;gap:14px;align-items:center}.brand img{width:58px;height:58px;border-radius:16px;object-fit:cover;background:white;padding:4px}.brand b{font-size:23px;letter-spacing:.04em}.brand span{display:block;font-size:12px;letter-spacing:.22em;color:rgba(255,255,255,.7);text-transform:uppercase}.btn{border:1px solid rgba(255,255,255,.25);border-radius:999px;padding:12px 22px;font-weight:850;background:transparent;color:white;cursor:pointer}.btn-primary{background:var(--cyan);border-color:var(--cyan);color:#02101d}.hero{padding:70px 0;background:radial-gradient(circle at 20% 10%,rgba(34,211,238,.18),transparent 32%),linear-gradient(135deg,#020817,#071827 54%,#0a1e58)}.hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center}.eyebrow{color:var(--cyan);text-transform:uppercase;letter-spacing:.28em;font-size:13px;font-weight:950;margin-bottom:18px}h1{font-size:clamp(42px,5.5vw,72px);line-height:1;margin:0;font-weight:950;letter-spacing:-.055em}.hero p{font-size:20px;line-height:1.65;color:rgba(255,255,255,.74)}.hero-card{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.07);border-radius:32px;padding:30px}.hero-card strong{font-size:50px;color:var(--cyan)}.section{padding:64px 0}.white{background:white;color:var(--ink)}.soft{background:var(--soft);color:var(--ink)}.panel{background:white;border:1px solid var(--line);border-radius:28px;box-shadow:0 18px 48px rgba(15,23,42,.08);overflow:hidden}.pad{padding:26px}.grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}.field label{display:block;font-weight:800;font-size:14px;margin-bottom:7px}.field input,.field select,.q select{width:100%;border:1px solid #cbd5e1;border-radius:14px;padding:12px;font-size:15px}.domain{border-top:1px solid var(--line);padding:26px}.domain:first-child{border-top:0}.domain-title{font-size:28px;font-weight:950}.muted{color:var(--muted)}.q{display:grid;grid-template-columns:1fr 220px;gap:18px;align-items:center;padding:15px 0;border-top:1px solid #eef2f7}.q p{margin:0;line-height:1.5}.actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:26px}.dashboard{display:none}.report{background:white;color:var(--ink);padding:36px;border-radius:28px;border:1px solid var(--line)}.report-head{display:flex;justify-content:space-between;gap:20px;align-items:center;border-bottom:2px solid #e2e8f0;padding-bottom:20px;margin-bottom:24px}.report-head img{width:150px;border-radius:18px}.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.kpi{border:1px solid var(--line);border-radius:24px;background:white;padding:22px}.kpi strong{font-size:36px;color:#0891b2;display:block}.bars{display:grid;gap:14px;margin-top:20px}.bar-row{display:grid;grid-template-columns:120px 1fr 60px;gap:12px;align-items:center}.bar-bg{height:15px;background:#e2e8f0;border-radius:999px;overflow:hidden}.bar-fill{height:100%;background:linear-gradient(90deg,#0b5fff,#22d3ee)}.two{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:30px}.risk,.road{border-radius:16px;padding:16px;margin-bottom:12px}.risk{border-left:5px solid #f97316;background:#fff7ed}.road{background:#f8fafc;border:1px solid #e2e8f0}.source-note{font-size:13px;color:#64748b;line-height:1.6;margin-top:18px}.radar{width:100%;max-width:390px}@media(max-width:900px){.hero-grid,.grid2,.two{grid-template-columns:1fr}.q{grid-template-columns:1fr}.kpis{grid-template-columns:1fr 1fr}.bar-row{grid-template-columns:1fr}}@media(max-width:600px){.kpis{grid-template-columns:1fr}h1{font-size:42px}.brand span{display:none}}@media print{.header,.hero,.form,.actions,.no-print{display:none!important}.dashboard{display:block!important}.section{padding:0}.report{border:0;border-radius:0}.container{width:100%}body{background:white;color:#0f172a}.page-break{page-break-before:always}}
</style></head><body>
<header class="header no-print"><div class="container nav"><a class="brand" href="/"><img src="/images/logo-original.jpeg" alt="ALLUNIFIED"/><div><b>ALLUNIFIED</b><span>Cyber Maturity Assessment</span></div></a><a class="btn" href="/">Volver al sitio</a></div></header>
<main><section class="hero no-print"><div class="container hero-grid"><div><div class="eyebrow">Assessment ejecutivo</div><h1>Conozca la madurez primaria de seguridad de su empresa.</h1><p>Evaluación rápida basada en las funciones del NIST Cybersecurity Framework 2.0 para obtener dashboard ejecutivo, riesgos prioritarios y roadmap inicial.</p><p style="font-size:13px;color:rgba(255,255,255,.62)">Herramienta de orientación inicial desarrollada por ALLUNIFIED. No es certificación, auditoría ni evaluación oficial de NIST.</p></div><aside class="hero-card"><strong>48</strong><p>preguntas · 6 dominios · 10 a 12 minutos</p><p>Resultado: dashboard ejecutivo e impresión PDF con branding ALLUNIFIED.</p></aside></div></section>
<section class="section white form"><div class="container"><div class="panel pad"><div class="eyebrow">Datos de la empresa</div><h2 style="font-size:42px;margin:0 0 22px">Inicio de evaluación</h2><div class="grid2"><div class="field"><label>Empresa</label><input id="company" placeholder="Nombre de la empresa"/></div><div class="field"><label>Sector</label><select id="sector"><option>PyME</option><option>Manufactura</option><option>Logística</option><option>Retail</option><option>Servicios profesionales</option><option>Otro</option></select></div><div class="field"><label>Responsable</label><input id="owner" placeholder="Nombre del responsable"/></div><div class="field"><label>Correo</label><input id="email" placeholder="correo@empresa.com"/></div></div></div><div class="panel" style="margin-top:24px">{domains.map(([id,name,sub,questions])=><section class="domain" data-domain={id}><div style="margin-bottom:18px"><div class="domain-title">{name}</div><div class="muted">{sub}</div></div>{questions.map((q,i)=><div class="q"><p><strong>{name.substring(0,2).toUpperCase()}{i+1}.</strong> {q}</p><select class="score" data-domain={id}>{scale.map((s,i)=><option value={i}>{s}</option>)}</select></div>)}</section>)}</div><div class="actions"><button class="btn btn-primary" type="button" onclick="calculateAssessment()">Generar dashboard</button><button class="btn" type="button" onclick="resetAssessment()" style="color:#0f172a">Limpiar</button></div></div></section>
<section id="dashboardSection" class="section soft dashboard"><div class="container"><div class="report" id="report"><div class="report-head"><div><div class="eyebrow" style="margin-bottom:8px">ALLUNIFIED Cyber Maturity Dashboard</div><h2 style="font-size:42px;margin:0">Reporte ejecutivo de madurez</h2><p class="muted" id="reportMeta"></p></div><img src="/images/logo-original.jpeg" alt="ALLUNIFIED"/></div><div class="kpis"><div class="kpi"><strong id="overallScore">0%</strong><span>Madurez general</span></div><div class="kpi"><strong id="levelName">Inicial</strong><span>Nivel</span></div><div class="kpi"><strong id="topDomain">-</strong><span>Dominio fuerte</span></div><div class="kpi"><strong id="weakDomain">-</strong><span>Prioridad</span></div></div><div class="two"><div><h3>Madurez por dominio</h3><div class="bars" id="bars"></div></div><div><h3>Radar ejecutivo</h3><svg class="radar" viewBox="0 0 420 360" id="radarSvg"></svg></div></div><div class="two page-break"><div><h3>Top riesgos iniciales</h3><div id="risks"></div></div><div><h3>Roadmap recomendado</h3><div id="roadmap"></div></div></div><p class="source-note">Basado en las funciones del NIST Cybersecurity Framework 2.0: Govern, Identify, Protect, Detect, Respond y Recover. Esta evaluación es una valoración primaria de madurez y no sustituye una auditoría formal ni certificación.</p></div><div class="actions no-print"><button class="btn btn-primary" onclick="window.print()">Generar PDF / Imprimir</button><a class="btn" style="color:#0f172a" href="mailto:contacto@allunifiedst.com?subject=Sesión ejecutiva ACMA">Solicitar sesión ejecutiva</a></div></div></section></main>
<script is:inline>
const labels={govern:'Govern',identify:'Identify',protect:'Protect',detect:'Detect',respond:'Respond',recover:'Recover'};function lvl(s){if(s>=85)return'Optimizado';if(s>=70)return'Gestionado';if(s>=50)return'Intermedio';if(s>=30)return'Básico';return'Inicial'}function calculateAssessment(){const r={};Object.keys(labels).forEach(d=>r[d]=[]);document.querySelectorAll('.score').forEach(s=>r[s.dataset.domain].push(Number(s.value)));const scores=Object.entries(r).map(([id,v])=>({id,label:labels[id],score:Math.round(v.reduce((a,b)=>a+b,0)/(v.length*5)*100)}));const overall=Math.round(scores.reduce((a,b)=>a+b.score,0)/scores.length);const top=[...scores].sort((a,b)=>b.score-a.score)[0];const weak=[...scores].sort((a,b)=>a.score-b.score)[0];dashboardSection.style.display='block';overallScore.textContent=overall+'%';levelName.textContent=lvl(overall);topDomain.textContent=top.label;weakDomain.textContent=weak.label;reportMeta.textContent=(company.value||'Empresa evaluada')+' · '+sector.value+' · '+(owner.value||'Responsable no especificado')+' · '+new Date().toLocaleDateString('es-MX');renderBars(scores);renderRadar(scores);renderRisks(scores);renderRoadmap(weak.id);dashboardSection.scrollIntoView({behavior:'smooth'});}function renderBars(scores){bars.innerHTML=scores.map(d=>`<div class="bar-row"><strong>${d.label}</strong><div class="bar-bg"><div class="bar-fill" style="width:${d.score}%"></div></div><span>${d.score}%</span></div>`).join('')}function renderRadar(scores){const cx=210,cy=180,maxR=125;const pts=scores.map((d,i)=>{const a=(-90+i*60)*Math.PI/180,r=maxR*d.score/100;return[cx+r*Math.cos(a),cy+r*Math.sin(a),d]});const axis=scores.map((d,i)=>{const a=(-90+i*60)*Math.PI/180;return[cx+maxR*Math.cos(a),cy+maxR*Math.sin(a),d]});radarSvg.innerHTML=`<polygon points="${axis.map(p=>p[0]+','+p[1]).join(' ')}" fill="none" stroke="#cbd5e1" stroke-width="2"/>${axis.map(p=>`<line x1="${cx}" y1="${cy}" x2="${p[0]}" y2="${p[1]}" stroke="#e2e8f0"/>`).join('')}<polygon points="${pts.map(p=>p[0]+','+p[1]).join(' ')}" fill="rgba(34,211,238,.35)" stroke="#0891b2" stroke-width="3"/>${axis.map(p=>`<text x="${p[0]}" y="${p[1]}" fill="#334155" font-size="13" font-weight="700" text-anchor="middle">${p[2].label}</text>`).join('')}`}function renderRisks(scores){const riskMap={govern:'Gobierno insuficiente para priorizar inversión y responsabilidades.',identify:'Visibilidad incompleta de activos, proveedores, cloud u OT.',protect:'Controles preventivos insuficientes para reducir exposición.',detect:'Baja capacidad de detección temprana.',respond:'Capacidad limitada para contener y comunicar incidentes.',recover:'Riesgo de recuperación lenta por DRP/BCP o respaldos no probados.'};risks.innerHTML=[...scores].sort((a,b)=>a.score-b.score).slice(0,3).map(d=>`<div class="risk"><strong>${d.label}: ${d.score}%</strong><br>${riskMap[d.id]}</div>`).join('')}function renderRoadmap(w){const a={govern:['Formalizar estrategia y responsable.','Definir indicadores y presupuesto.','Crear comité de riesgos tecnológicos.'],identify:['Actualizar inventarios.','Clasificar información y servicios críticos.','Mapear red, cloud y OT.'],protect:['Implementar MFA.','Revisar respaldos, EDR y privilegios.','Ejecutar awareness focalizado.'],detect:['Centralizar logs críticos.','Definir alertas prioritarias.','Iniciar gestión de vulnerabilidades.'],respond:['Crear plan de respuesta.','Definir roles y comunicación.','Realizar tabletop exercise.'],recover:['Definir RTO/RPO.','Probar recuperación de respaldos.','Actualizar DRP/BCP anti-ransomware.']};roadmap.innerHTML=`<div class="road"><strong>0-90 días</strong><br>${a[w][0]}</div><div class="road"><strong>90-180 días</strong><br>${a[w][1]}</div><div class="road"><strong>180-360 días</strong><br>${a[w][2]}</div>`}function resetAssessment(){document.querySelectorAll('.score').forEach(s=>s.value='0');dashboardSection.style.display='none'}
</script></body></html>
