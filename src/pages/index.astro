---
const services = [
  ['IT Infrastructure Assessment', 'Diagnóstico de red, servidores, nube, operación, riesgos y continuidad.', 'Infraestructura'],
  ['Cybersecurity Executive Assessment', 'Evaluación ejecutiva de controles, exposición y roadmap alineado a NIST e ISO 27001.', 'Ciberseguridad'],
  ['IT/OT Convergence', 'Acompañamiento para plantas, manufactura y ambientes industriales con Purdue, segmentación y operación segura.', 'Industria'],
  ['Microsoft 365 & Cloud', 'Optimización, seguridad, migración y gobierno de Microsoft 365 y nube híbrida.', 'Cloud'],
  ['Managed IT & Security Services', 'Soporte operativo, monitoreo, hardening, continuidad y mejora continua.', 'Operación'],
  ['GRC & AI Governance', 'Gobierno, riesgo y cumplimiento con ISO 27001, ISO 37301 e ISO 42001.', 'Gobierno']
];
const sectors = ['PyMEs', 'Manufactura', 'Logística', 'Retail', 'Centros operativos', 'Servicios profesionales'];
const frameworks = ['NIST', 'ISO 27001', 'ISO 37301', 'ISO 42001', 'Purdue Model', 'ISA/IEC 62443', 'COBIT', 'ITIL'];
const cases = [
  ['SOC/NOC', 'Visibilidad operativa, correlación de eventos, respuesta y comunicación ejecutiva.'],
  ['Segmentación IT/OT', 'Separación de redes industriales, DMZ, control de accesos y continuidad operativa.'],
  ['Microsoft 365', 'MFA, gobierno, correo, colaboración, seguridad y operación híbrida.'],
  ['Red empresarial', 'LAN, WAN, WiFi, firewalls, VPN, alta disponibilidad y resiliencia.']
];
---
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="ALLUNIFIED Servicios Tecnológicos: infraestructura TI, ciberseguridad, IT/OT, Microsoft 365, nube y gobierno tecnológico para PyMEs e industria." />
<title>ALLUNIFIED Servicios Tecnológicos</title>
<style>
:root{--bg:#020817;--cyan:#22d3ee;--blue:#0b5fff;--muted:#cbd5e1;--ink:#0f172a;--soft:#f4f7fb}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:white;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}a{color:inherit;text-decoration:none}.container{width:min(1200px,calc(100% - 42px));margin:auto}
.header{position:fixed;inset:0 0 auto;z-index:50;background:rgba(2,8,23,.78);backdrop-filter:blur(18px);border-bottom:1px solid rgba(255,255,255,.1)}.nav{height:88px;display:flex;align-items:center;justify-content:space-between;gap:24px}.brand{display:flex;align-items:center;gap:15px}.brand img{width:60px;height:60px;object-fit:cover;border-radius:18px;background:white;padding:4px}.brand-title{font-size:25px;font-weight:950;letter-spacing:.04em;line-height:1}.brand-sub{margin-top:7px;color:rgba(255,255,255,.74);font-size:13px;letter-spacing:.25em;text-transform:uppercase;font-weight:600}.menu{display:flex;gap:32px;color:rgba(255,255,255,.68);font-size:15px;font-weight:650}.menu a:hover{color:var(--cyan)}
.btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:14px 26px;font-weight:850;border:1px solid rgba(255,255,255,.25);transition:.22s ease;white-space:nowrap}.btn:hover{transform:translateY(-2px)}.btn-primary{background:var(--cyan);color:#02101d;border-color:var(--cyan);box-shadow:0 18px 55px rgba(34,211,238,.2)}.btn-outline:hover{border-color:var(--cyan);color:var(--cyan)}
.hero{position:relative;min-height:100vh;overflow:hidden;padding:172px 0 105px;background:radial-gradient(circle at 17% 20%,rgba(34,211,238,.18),transparent 28%),radial-gradient(circle at 84% 12%,rgba(11,95,255,.32),transparent 35%),linear-gradient(135deg,#020817 0%,#071827 48%,#0a1e58 100%)}.hero:before{content:"";position:absolute;inset:0;opacity:.15;background-image:linear-gradient(rgba(255,255,255,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.08) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(circle at 50% 30%,black,transparent 70%)}.hero-grid{position:relative;z-index:2;display:grid;grid-template-columns:1.02fr .98fr;gap:74px;align-items:center}.eyebrow{margin-bottom:24px;color:var(--cyan);text-transform:uppercase;letter-spacing:.32em;font-size:13px;line-height:1.7;font-weight:950}h1{margin:0;max-width:720px;font-size:clamp(52px,6.3vw,86px);line-height:.98;letter-spacing:-.065em;font-weight:950}.hero-copy{margin:34px 0 0;max-width:670px;color:rgba(255,255,255,.76);font-size:21px;line-height:1.68}.hero-actions{margin-top:42px;display:flex;gap:18px;flex-wrap:wrap}
.advisory{border:1px solid rgba(255,255,255,.13);background:linear-gradient(160deg,rgba(255,255,255,.09),rgba(255,255,255,.045));border-radius:38px;padding:38px;box-shadow:0 34px 95px rgba(0,0,0,.32);backdrop-filter:blur(20px)}.advisory-title{margin-bottom:34px;color:rgba(255,255,255,.74);text-transform:uppercase;letter-spacing:.3em;font-size:13px;font-weight:950}.stats{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.stat{border:1px solid rgba(255,255,255,.1);background:rgba(2,8,23,.48);border-radius:26px;padding:26px}.stat strong{display:block;color:var(--cyan);font-size:52px;line-height:.95;letter-spacing:-.05em;font-weight:950}.stat span{display:block;margin-top:10px;color:rgba(255,255,255,.66);font-size:15px;line-height:1.4}.framework-box{margin-top:22px;border:1px solid rgba(34,211,238,.22);background:rgba(34,211,238,.1);color:#c8f7ff;border-radius:26px;padding:24px;line-height:1.55;font-size:18px;font-weight:800}.framework-box small{display:block;margin-top:7px;color:rgba(255,255,255,.72);font-size:15px;font-weight:500}.trusted{position:relative;z-index:2;margin-top:70px;color:rgba(255,255,255,.55);font-size:13px;text-transform:uppercase;letter-spacing:.22em;font-weight:850}.trusted-row{margin-top:18px;display:flex;gap:12px;flex-wrap:wrap}.trusted-pill{border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:10px 16px;color:rgba(255,255,255,.7);text-transform:none;letter-spacing:normal;font-size:14px;font-weight:750;background:rgba(255,255,255,.04)}
.section{padding:110px 0}.white{background:white;color:var(--ink)}.gray{background:var(--soft);color:var(--ink)}.dark{background:var(--bg);color:white}.section-title{margin:12px 0 0;max-width:890px;font-size:clamp(38px,5vw,64px);line-height:1.05;letter-spacing:-.055em;font-weight:950}.section-copy{max-width:790px;color:#64748b;font-size:20px;line-height:1.72;margin-top:24px}.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:58px}.service-card{border:1px solid #e2e8f0;background:#fff;border-radius:30px;padding:32px;min-height:285px;transition:.25s ease;box-shadow:0 12px 28px rgba(15,23,42,.05)}.service-card:hover{transform:translateY(-5px);box-shadow:0 32px 75px rgba(15,23,42,.14)}.service-tag{display:inline-flex;border-radius:999px;background:#e0f7ff;color:#0369a1;padding:7px 12px;font-size:12px;font-weight:900;margin-bottom:22px}.service-card h3{margin:0;font-size:27px;line-height:1.1;letter-spacing:-.03em}.service-card p,.case-card p,.step p{color:#64748b;line-height:1.68}
.method-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:58px;align-items:start}.steps{display:grid;gap:18px}.step{background:white;border-radius:30px;padding:30px;box-shadow:0 13px 35px rgba(15,23,42,.07)}.step-num{color:#0891b2;font-size:14px;font-weight:950}.step h3{margin:8px 0 0;font-size:25px}.sectors-grid,.framework-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:58px}.sector,.framework{border:1px solid rgba(255,255,255,.11);background:rgba(255,255,255,.06);border-radius:28px;padding:30px;font-size:22px;font-weight:950;min-height:110px;display:flex;align-items:center}.framework{color:#c8f7ff}.case-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin-top:58px}.case-card{border:1px solid #e2e8f0;background:white;border-radius:30px;padding:34px}.case-card h3{margin:0;font-size:30px;letter-spacing:-.04em}.contact{text-align:center}.contact .section-title,.contact .section-copy{margin-left:auto;margin-right:auto}.contact .section-copy{color:rgba(255,255,255,.7)}.contact-actions{margin-top:42px;display:flex;justify-content:center;gap:16px;flex-wrap:wrap}footer{border-top:1px solid rgba(255,255,255,.1);background:#020817;color:rgba(255,255,255,.56);padding:32px 0}.footer-row{display:flex;justify-content:space-between;gap:18px;flex-wrap:wrap}.reveal{animation:rise .65s ease both}@keyframes rise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:980px){.menu{display:none}.hero-grid,.method-grid{grid-template-columns:1fr}.services-grid{grid-template-columns:1fr}.sectors-grid,.framework-grid{grid-template-columns:repeat(2,1fr)}.case-grid{grid-template-columns:1fr}.hero{padding-top:135px}h1{font-size:54px}}@media(max-width:620px){.brand-sub{display:none}.brand-title{font-size:19px}.brand img{width:50px;height:50px}.nav{height:78px}.stats{grid-template-columns:1fr}.sectors-grid,.framework-grid{grid-template-columns:1fr}.hero-actions,.contact-actions{flex-direction:column}h1{font-size:46px}.section{padding:80px 0}}
</style>
</head>
<body>
<header class="header"><div class="container nav"><a class="brand" href="#"><img src="/images/logo-original.jpeg" alt="ALLUNIFIED Servicios Tecnológicos"/><div><div class="brand-title">ALLUNIFIED</div><div class="brand-sub">Servicios Tecnológicos</div></div></a><nav class="menu"><a href="#servicios">Servicios</a><a href="#metodologia">Metodología</a><a href="#sectores">Sectores</a><a href="#casos">Casos</a><a href="#contacto">Contacto</a></nav><a class="btn btn-outline" href="/assessment">Evaluación gratuita</a></div></header>
<main>
<section class="hero"><div class="container hero-grid"><div class="reveal"><div class="eyebrow">Servicios tecnológicos para operación real</div><h1>Infraestructura estable, segura y alineada al negocio.</h1><p class="hero-copy">Evaluamos, fortalecemos y evolucionamos infraestructuras tecnológicas para organizaciones que necesitan continuidad operativa, ciberseguridad y crecimiento seguro.</p><div class="hero-actions"><a class="btn btn-primary" href="#contacto">Solicitar diagnóstico</a><a class="btn btn-outline" href="#servicios">Ver servicios</a></div></div><aside class="advisory reveal"><div class="advisory-title">Executive Technology Advisory</div><div class="stats"><div class="stat"><strong>27+</strong><span>años de experiencia</span></div><div class="stat"><strong>650+</strong><span>usuarios protegidos</span></div><div class="stat"><strong>24/7</strong><span>operación crítica</span></div><div class="stat"><strong>IT/OT</strong><span>convergencia segura</span></div></div><div class="framework-box">NIST · ISO 27001 · ISO 42001 · Purdue · ISA/IEC 62443<small>Gobierno, seguridad y continuidad operativa con enfoque ejecutivo.</small></div></aside></div><div class="container trusted">Tecnologías y marcos con los que trabajamos<div class="trusted-row"><span class="trusted-pill">Microsoft 365</span><span class="trusted-pill">Azure</span><span class="trusted-pill">Palo Alto</span><span class="trusted-pill">Aruba</span><span class="trusted-pill">Fortinet</span><span class="trusted-pill">Red Hat</span><span class="trusted-pill">SAP</span><span class="trusted-pill">NIST</span><span class="trusted-pill">ISO 27001</span></div></div></section>
<section id="servicios" class="section white"><div class="container"><div class="eyebrow">Servicios</div><h2 class="section-title">Soluciones para organizaciones que necesitan tecnología confiable.</h2><p class="section-copy">Evaluamos, diseñamos y acompañamos la evolución tecnológica con enfoque realista, ejecutivo y orientado a continuidad operativa.</p><div class="services-grid">{services.map(([title,text,tag])=><article class="service-card"><span class="service-tag">{tag}</span><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>
<section id="metodologia" class="section gray"><div class="container method-grid"><div><div class="eyebrow">Metodología</div><h2 class="section-title">De la anomalía técnica al riesgo de negocio.</h2><p class="section-copy">No vendemos tecnología por moda. Traducimos hallazgos técnicos en decisiones ejecutivas, prioridades y planes viables.</p></div><div class="steps">{['Descubrimiento','Evaluación de riesgos','Roadmap de remediación','Acompañamiento ejecutivo'].map((step,index)=><article class="step"><div class="step-num">0{index+1}</div><h3>{step}</h3><p>Priorizamos acciones por impacto, urgencia, costo, riesgo y valor operativo.</p></article>)}</div></div></section>
<section id="sectores" class="section dark"><div class="container"><div class="eyebrow">Sectores</div><h2 class="section-title">Experiencia aplicable a operación real.</h2><div class="sectors-grid">{sectors.map((sector)=><div class="sector">{sector}</div>)}</div></div></section>
<section class="section dark"><div class="container"><div class="eyebrow">Frameworks</div><h2 class="section-title">Gobierno, seguridad y continuidad con bases reconocidas.</h2><div class="framework-grid">{frameworks.map((framework)=><div class="framework">{framework}</div>)}</div></div></section>
<section id="casos" class="section white"><div class="container"><div class="eyebrow">Casos de uso</div><h2 class="section-title">Experiencia que se traduce en ejecución.</h2><div class="case-grid">{cases.map(([title,text])=><article class="case-card"><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>
<section id="contacto" class="section dark contact"><div class="container"><div class="eyebrow">Contacto</div><h2 class="section-title">Hablemos de tu infraestructura.</h2><p class="section-copy">Agenda una conversación inicial para identificar riesgos, oportunidades y prioridades tecnológicas.</p><div class="contact-actions"><a class="btn btn-primary" href="mailto:contacto@allunifiedst.com">contacto@allunifiedst.com</a><a class="btn btn-primary" href="https://wa.me/525599152707">WhatsApp</a><a class="btn btn-outline" href="https://www.linkedin.com/in/all-unified-servicios-tecnologicos">LinkedIn</a></div></div></section>
<section class="section white"><div class="container"><div class="eyebrow">Herramienta ejecutiva</div><h2 class="section-title">Inicie con una valoración primaria de madurez en seguridad.</h2><p class="section-copy">Complete una evaluación basada en NIST CSF 2.0 y genere un dashboard ejecutivo imprimible en PDF con branding ALLUNIFIED.</p><div class="hero-actions"><a class="btn btn-primary" href="/assessment">Comenzar assessment</a><a class="btn btn-outline" style="color:#0f172a;border-color:#cbd5e1" href="#contacto">Solicitar acompañamiento</a></div></div></section></main>
<footer><div class="container footer-row"><span>© 2026 ALLUNIFIED Servicios Tecnológicos</span><span>Infraestructura · Ciberseguridad · IT/OT · Cloud · Gobierno</span></div></footer>
</body>
</html>
